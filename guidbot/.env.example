# ══════════════════════════════════════════════════════════════════════
#  .env.example ─ 환경변수 설정 예시
#  실제 사용: 이 파일을 .env 로 복사 후 값 입력
#  명령: copy .env.example .env  (Windows)
#        cp .env.example .env    (Linux/Mac)
#
#  [보안 규칙]
#  - .env 파일은 절대 Git 에 커밋하지 마세요 (.gitignore 에 등록 필수)
#  - API 키·비밀번호를 소스코드에 직접 입력하지 마세요
#  - 운영 환경에서는 OS 환경변수 또는 Vault/SecretManager 사용 권장
# ══════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────
#  Google Gemini API 설정 (필수)
#  발급: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────

# 기본 API 키 (필수 — 없으면 앱 시작 불가)
GOOGLE_API_KEY=여기에_실제_API_키_입력

# 할당량 초과(429) 시 자동 전환할 예비 키 (선택, 최대 4개)
# 운영 환경에서 365일 무중단 서비스를 위해 2~3개 준비 권장
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
# GOOGLE_API_KEY_5=AIzaSy_다섯번째_키

# LLM 모델 선택 (기본값: gemini-2.5-flash)
# models/gemini-2.5-flash  → 추론 OFF 시 3~5초, 기본 권장
# models/gemini-2.0-flash  → 2~4초, 빠름
# models/gemini-2.0-flash-lite → 1~2초, 가장 빠름 (정확도 소폭 저하)
CHAT_MODEL=models/gemini-2.5-flash

# Gemini 2.5-flash 추론(thinking) 단계 비활성화
# True: 21초 → 3~5초 단축 (병원 규정 Q&A 에 추천)
# False: 정확도 소폭 향상, 속도 저하
# LLM_THINKING_DISABLED=true

# LLM 최대 출력 토큰 (기본: 1024, 범위: 256~8192)
# LLM_MAX_OUTPUT_TOKENS=1024

# LLM 온도 (기본: 0.1, 낮을수록 일관된 답변)
# LLM_TEMPERATURE=0.1

# ──────────────────────────────────────────────────────────────────────
#  보안 설정
# ──────────────────────────────────────────────────────────────────────

# 관리자 패널 패스워드 (최소 12자, 특수문자 포함 강력 권장)
# 기본값 'moonhwa' 는 개발용 — 운영 환경에서 반드시 변경!
ADMIN_PASSWORD=반드시_강력한_패스워드로_변경하세요

# ──────────────────────────────────────────────────────────────────────
#  병원 DB 연결 설정 (선택 — DB 스키마 RAG 연동 시에만 필요)
# ──────────────────────────────────────────────────────────────────────

# DB 기능 활성화 여부 (true 설정 시 아래 항목도 필수)
# DB_ENABLED=false

# DB 종류: mysql (MariaDB 포함) / mssql / postgresql
# DB_TYPE=mysql

# DB 서버 정보
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=hospital_db

# DB 계정 (SELECT 전용 계정 강력 권장 — DML 권한 부여 절대 금지)
# DB_USER=rag_readonly
# DB_PASSWORD=읽기전용_계정_패스워드

# ──────────────────────────────────────────────────────────────────────
#  RAG 파이프라인 파라미터 (선택 — 기본값으로 충분)
# ──────────────────────────────────────────────────────────────────────

# 청크 크기 (기본: 1000자)
# CHUNK_SIZE=1000

# 청크 오버랩 (기본: 200자, chunk_size 보다 작아야 함)
# CHUNK_OVERLAP=200

# FAISS 1차 검색 후보 수 (기본: 20)
# RETRIEVE_TOP_K=20

# CE 리랭킹 후 최종 문서 수 (기본: 3, retrieve_top_k 이하여야 함)
# RERANK_TOP_N=3

# Cross-Encoder 모델 오버라이드
# CE_MODEL=bongsoo/kpf-cross-encoder-v1  ← 한국어 특화 (느리지만 정확)

# ──────────────────────────────────────────────────────────────────────
#  Query Rewriting 설정 (선택)
# ──────────────────────────────────────────────────────────────────────

# 쿼리 재작성 활성화 (기본: true)
# QUERY_REWRITING_ENABLED=true

# Multi-Query 확장 활성화 (기본: true) — 질문 1개 → 3개로 확장
# QUERY_MULTI_ENABLED=true

# HyDE 활성화 (기본: false) — 가상 문서 임베딩 (실험적)
# QUERY_HYDE_ENABLED=false

# ──────────────────────────────────────────────────────────────────────
#  모니터링 (선택)
# ──────────────────────────────────────────────────────────────────────

# 성능 메트릭 수집 (기본: true)
# MONITORING_ENABLED=true

# ──────────────────────────────────────────────────────────────────────
#  Streamlit 서버 설정 (선택)
# ──────────────────────────────────────────────────────────────────────

# 앱 제목 (브라우저 탭에 표시)
# APP_TITLE=좋은문화병원 가이드봇

# 서버 바인딩 IP (0.0.0.0=LAN 전체 허용, 127.0.0.1=로컬 전용)
# SERVER_IP=0.0.0.0
